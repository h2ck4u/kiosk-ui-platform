{
  "name": "kiosk-ui-platform",
  "version": "1.0.0",
  "description": "Kiosk UI Platform - Monorepo for @kiosk-ui design system",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @kiosk-ui/components build",
    "dev": "pnpm --filter @kiosk-ui/components dev",
    "storybook": "pnpm --filter @kiosk-ui/components storybook",
    "build-storybook": "pnpm --filter @kiosk-ui/components build-storybook",
    "type-check": "pnpm --filter @kiosk-ui/components type-check",
    "lint": "eslint packages/",
    "tokens:sync": "pnpm --filter kiosk-figma-tokens sync:build-only",
    "tokens:sync:figma": "pnpm --filter kiosk-figma-tokens sync"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript-eslint": "^8.57.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
